# ============================================================
# Web Page Cloner 环境变量配置
# 复制本文件为 .env 并按需修改。所有变量都有默认值，不配置也能运行。
# ============================================================

# ---------- 资源下载 ----------
# 静态资源（图片/CSS/JS 等）最大并发下载数
DOWNLOAD_CONCURRENCY=20
# 单个资源下载失败后的最大重试次数
MAX_RETRIES=3
# 单个资源下载超时时间（毫秒）
DOWNLOAD_TIMEOUT=15000

# ---------- 克隆任务 ----------
# 临时文件自动清理延迟（毫秒），默认 1 小时
AUTO_CLEANUP_DELAY=3600000
# SSE 心跳检查间隔（毫秒）
HEARTBEAT_INTERVAL=15000
# 超过该时长无消息则发送心跳（毫秒）
HEARTBEAT_THRESHOLD=20000

# ---------- 多页爬取 ----------
# 页面之间的最小随机延迟（毫秒）
MIN_PAGE_DELAY=1500
# 页面之间的最大随机延迟（毫秒）
MAX_PAGE_DELAY=3500
# 每一层深度最多发现并跟踪的链接数
MAX_LINKS_PER_DEPTH=10

# ---------- 代理（可选，用于访问被网络限制的站点）----------
# 注意：此变量尚未接入代码，仅作占位。如需支持请提 issue。
# CLONE_PROXY=http://127.0.0.1:7890

# ---------- 统计分析（可选）----------
# 百度统计 ID，不配置则不启用统计
# 获取方式：https://tongji.baidu.com/
# NEXT_PUBLIC_BAIDU_ANALYTICS_ID=your_baidu_analytics_id
